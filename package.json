{
  "name": "reviewcartdeals",
  "version": "1.0.0",
  "description": "Review cart deals storefront with Payload CMS on Cloudflare Workers",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "migrate:production": "NODE_ENV=production PAYLOAD_SECRET=${PAYLOAD_SECRET:-ignore} payload migrate",
    "prebuild": "bun run migrate:production && NODE_ENV=production VINEXT_BUILD=1 NODE_OPTIONS=--no-deprecation bunx tsx src/scripts/write-build-slugs.ts",
    "build": "bun run prebuild && NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" vinext build",
    "deploy": "bun run deploy:database && bun run deploy:app",
    "deploy:app": "bun run build && vinext deploy",
    "deploy:database": "bun run migrate:production && bunx wrangler d1 execute D1 --command 'PRAGMA optimize' --remote",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "predev": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation vinext dev",
    "devsafe": "rm -rf dist .vinext && cross-env NODE_OPTIONS=--no-deprecation vinext dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "bun run generate:types:cloudflare && bun run generate:types:payload",
    "generate:types:cloudflare": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "generate:types:payload": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test:unit",
    "lint": "oxlint src",
    "typecheck": "tsgo --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "preview": "bun run build && wrangler dev",
    "start": "cross-env NODE_OPTIONS=--no-deprecation wrangler dev",
    "test": "bun run test:unit && bun run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:unit": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@payloadcms/db-d1-sqlite": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/storage-r2": "3.85.0",
    "@tailwindcss/postcss": "^4.3.0",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "payload": "3.85.0",
    "postcss": "^8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@playwright/test": "1.60.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260608.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-rsc": "^0.5.27",
    "husky": "^9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "react-server-dom-webpack": "^19.2.7",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vinext": "0.0.50",
    "vite": "^8.0.16",
    "vite-plugin-vinext-payload": "^0.0.19",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.8",
    "wrangler": "~4.98.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mts,cts,json,jsonc}": "oxfmt --write",
    "*.{js,jsx,ts,tsx,mts,cts}": "oxlint"
  },
  "engines": {
    "node": ">=22"
  },
  "cloudflare": {
    "bindings": {
      "PAYLOAD_SECRET": {
        "description": "Generate a random string using `openssl rand -hex 32`"
      }
    }
  }
}
