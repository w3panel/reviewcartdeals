{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "semi": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "**/node_modules/**",
    ".next/**",
    ".open-next/**",
    "out/**",
    "build/**",
    "bundled/**",
    "next-env.d.ts",
    "cloudflare-env.d.ts",
    "src/payload-types.ts",
    "src/payload-generated-schema.ts"
  ]
}
