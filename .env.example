# Payload
PAYLOAD_SECRET=

# PostgreSQL (local example — matches docker-compose.yml)
DATABASE_URI=postgresql://reviewcartdeals:reviewcartdeals@localhost:5432/reviewcartdeals

# Production (Neon on Vercel):
# DATABASE_URI — pooled URL (-pooler host) for runtime
# DATABASE_URL_DIRECT — direct URL (no -pooler) for migrations only
# DATABASE_CONNECT_TIMEOUT_MS=30000 — optional; helps Neon wake from idle
# Keep Neon and Vercel in the same region (e.g. ap-southeast-1).

# Cloudflare R2 media (S3-compatible API)
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Storefront
NEXT_PUBLIC_WHATSAPP_NUMBER=
